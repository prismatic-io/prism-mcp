{
  "name": "@prismatic-io/prism-mcp",
  "version": "1.4.2",
  "mcpName": "io.github.prismatic-io/prism-mcp",
  "description": "MCP server that wraps Prismatic's Prism CLI tool",
  "keywords": ["prismatic"],
  "main": "dist/index.js",
  "type": "module",
  "homepage": "https://prismatic.io",
  "bugs": {
    "url": "https://github.com/prismatic-io/prism-mcp/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/prismatic-io/prism-mcp.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": ["dist/"],
  "license": "MIT",
  "bin": {
    "prism-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod 755 dist/index.js",
    "dev": "bun src/index.ts",
    "start": "node dist/index.js",
    "check": "biome check .",
    "check:fix": "biome check --write ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "lodash-es": "^4.17.23",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.6.3",
    "@types/bun": "^1.3.12",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "types": "./dist/index.d.ts",
  "trustedDependencies": ["@biomejs/biome"]
}
